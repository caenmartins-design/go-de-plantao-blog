# ============================================================
# GO DE PLANTÃO — Newsletter | Configuração de Ambiente
# Copie este arquivo para .env e preencha os valores
# ============================================================

# Claude API (obrigatório para curadoria com IA)
ANTHROPIC_API_KEY=sk-ant-...

# ── E-MAIL (SMTP) ───────────────────────────────────────────
# Gmail: use senha de app em myaccount.google.com/apppasswords
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_REMETENTE=seuemail@gmail.com
EMAIL_SENHA=xxxx xxxx xxxx xxxx
EMAIL_NOME_REMETENTE=GO de Plantão Newsletter
# Lista de destinatários separados por vírgula
EMAIL_DESTINATARIOS=medico1@ex.com,medico2@ex.com
# Assunto padrão (semana/data são inseridos automaticamente)
EMAIL_ASSUNTO=GO de Plantão | Atualização Semanal em GO

# ── INSCRIÇÕES VIA FORMULÁRIO ────────────────────────────────
# URL de publicação CSV da planilha de respostas do Google Forms
# (na planilha: Arquivo > Compartilhar > Publicar na web > formato CSV)
NEWSLETTER_SIGNUP_CSV_URL=https://docs.google.com/spreadsheets/d/e/SEU_ID/pub?output=csv

# ── WHATSAPP — Escolha UMA das opções abaixo ────────────────

# Opção 1: Z-API (https://z-api.io)
ZAPI_INSTANCE_ID=
ZAPI_TOKEN=
ZAPI_CLIENT_TOKEN=
# Números no formato internacional (sem +), separados por vírgula
ZAPI_NUMEROS=5511999999999,5511888888888

# Opção 2: Evolution API (self-hosted, https://evolution-api.com)
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=go-plantao
EVOLUTION_NUMEROS=5511999999999,5511888888888

# ── CONFIGURAÇÕES DE BUSCA ───────────────────────────────────
# Número de dias para buscar artigos recentes
DIAS_RETROATIVOS=7
# Máximo de artigos a buscar por fonte
MAX_POR_FONTE=20
# Máximo de artigos na newsletter final (após curadoria)
MAX_NEWSLETTER=10

# ── URL DO BLOG (para links na newsletter) ───────────────────
BLOG_URL=https://go-de-plantao.pages.dev
